# Copy this file to .env and fill in your values.

# Required: GitHub personal access token (needs repo scope for cloning/pushing)
GITHUB_TOKEN=ghp_...

# Chamber repository URLs are deployment-specific: declare them in chambers.json
# (a `url`, or a `url_env` naming an environment variable you set here). The
# shipped chambers.example.json mounts the local example chambers and needs none.
# Example, if a chamber entry uses "url_env": "MY_CHAMBER_REPO":
# MY_CHAMBER_REPO=https://github.com/your-username/your-chamber.git

# Deployment-defined SPARQL stores (extra compose services declared in
# docker-compose.override.yml and advertised there via SPARQL_ENDPOINT_*):
# comma-separated service hostnames to exempt from the egress-audit proxy.
# SPARQL_NO_PROXY=qlever-genomics

# Required for signal-gateway: Signal account (phone number) used by signal-cli
SIGNAL_ACCOUNT=+15551234567

# What the signal-gateway account is for. Fixed by configuration; never inferred
# from message content. One of:
#   inbox   — (default) the account is one of the user's own message sources,
#             like an e-mail inbox. Inbound messages are handed to triage as the
#             user's incoming mail and surfaced on the dashboard (push
#             notification); they are never run as prompts and no reply is sent
#             to the sender.
#   control — the account is a control channel for operating Retinue (the
#             classic gateway). Inbound messages are run as prompts to Ara, who
#             replies on the same channel. Access is restricted to the
#             accepted-requesters allowlist (see README "Accepted requesters");
#             non-allowlisted senders are refused.
# The default is "inbox" so an account cannot drive the system unless you
# explicitly opt in with SIGNAL_GATEWAY_MODE=control.
SIGNAL_GATEWAY_MODE=inbox

# To run several messaging accounts, add one signal-gateway service per account
# in docker-compose.override.yml, each with its own SIGNAL_ACCOUNT,
# SIGNAL_GATEWAY_MODE and its own signal-data volume (never shared between
# accounts). See docker-compose.override.example.yml and the README
# "Messaging accounts" section for a worked example.

# Optional for signal-gateway: restrict language detection to the languages you
# actually speak (comma-separated ISO 639-1 codes). This constrains langdetect
# (text) here and, via STT_SUPPORTED_LANGUAGES, the shared STT service (voice),
# preventing bogus guesses like Latin or Finnish that produce unintelligible
# replies. Leave unset to auto-detect any language.
# SIGNAL_SUPPORTED_LANGUAGES=de,en

# Optional for signal-gateway: override language-to-Piper-model map (JSON object)
# PIPER_MODEL_MAP={"en":"en_US-lessac-medium","de":"de_DE-thorsten-high"}

# Optional LiteLLM gateway: uses the Claude Code Max/Pro subscription first,
# then falls back to OpenRouter when Anthropic returns an upstream error.
# ANTHROPIC_API_KEY=
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=http://litellm:4000
# ANTHROPIC_CUSTOM_HEADERS=x-litellm-api-key: Bearer sk-retinue-...
# RETINUE_CLAUDE_MODEL=retinue-claude
# RETINUE_GATEWAY_USES_CLAUDE_OAUTH=true
# LITELLM_MASTER_KEY=sk-retinue-...
# LITELLM_PRIMARY_MODEL=anthropic/claude-sonnet-4-20250514
# LITELLM_FALLBACK_MODEL=openrouter/anthropic/claude-sonnet-4
# OPENROUTER_API_KEY=sk-or-v1-...
# LITELLM_DB_PASSWORD=replace-with-a-random-password
# DATABASE_URL=postgresql://litellm:replace-with-a-random-password@litellm-db:5432/litellm
# PROXY_ADMIN_ID=admin

# Optional shared secret for the STT (speech-to-text) service. When set,
# POST /transcribe requires it; the web gateway and signal-gateway (both
# clients) and the stt service all read it, so set it once. The service is only
# reachable on the internal `agents` network, so this is defence-in-depth.
# STT_TOKEN=

# Outbound Signal push (scripts/signal-push.py → signal-gateway /send endpoint).
# Lets Ara initiate messages — alerts, escalations, daily briefings — with a
# spoken audio rendering and optional images, the same pipeline as replies.
#   SIGNAL_DEFAULT_RECIPIENT: who pushes go to when no recipient is given (the
#                             system owner's Signal number, E.164).
#   SIGNAL_GATEWAY_TOKEN:     shared secret; when set, /send requires it. Both
#                             the gateway and retinue read it, so set it once.
# SIGNAL_DEFAULT_RECIPIENT=+15551234567
# SIGNAL_GATEWAY_TOKEN=

# Optional for signal-gateway: outbound send-control policy — the messenger
# analogue of EMAIL_SEND_POLICY. Like e-mail, the category is keyed by the
# SENDING identity (this gateway's own SIGNAL_ACCOUNT number), NOT the recipient:
# what governs an autonomous send is which number it goes out as. A dedicated
# agent number can be granted "allow" while the user's own number stays "verify".
# Categories:
#   allow  — send directly, no confirmation (e.g. a dedicated agent number).
#   trust  — send directly only when signal-push.py passes --user-approved;
#            otherwise the send falls back to the verify flow.
#   verify — register the send as pending; it is transmitted only after explicit
#            web-gateway approval at /sends (an agent can never approve its own).
# An account matching no entry and no "*" wildcard falls back to verify
# (fail-safe, same as e-mail). Pending sends appear on /sends alongside e-mail.
# SIGNAL_SEND_POLICY=[{"number":"+15551234567","category":"verify"},{"number":"+15558888888","category":"allow"}]
#
# Public base URL used to build the approval link returned to the caller when a
# send is queued for verification (e.g. https://agents.example.com). When unset,
# a relative /sends path is returned.
# SEND_APPROVAL_BASE_URL=

# Outbound WhatsApp push (scripts/whatsapp-push.py → whatsapp-gateway /send).
# The messenger sibling of the Signal gateway: a dedicated service owns the
# linked-device WhatsApp Web session (its keys live only in that container), so
# agents send through a thin CLI with no MCP tool schema in context.
#   WHATSAPP_ACCOUNT:          this gateway's own number (E.164, the linked
#                              device). Send-control keys off THIS number (below).
#   WHATSAPP_GATEWAY_MODE:     "inbox" (default — the user's own message source,
#                              forwarded to triage, no reply) or "control" (runs
#                              messages as prompts to Ara, restricted to accepted
#                              requesters). Link the device once by scanning the
#                              pairing QR printed to the gateway's logs.
#   WHATSAPP_DEFAULT_RECIPIENT: who pushes go to when no recipient is given.
#   WHATSAPP_GATEWAY_TOKEN:    shared secret; when set, /send requires it. Both
#                              the gateway and retinue read it, so set it once.
# WHATSAPP_ACCOUNT=+15551234567
# WHATSAPP_GATEWAY_MODE=inbox
# WHATSAPP_DEFAULT_RECIPIENT=+15551234567
# WHATSAPP_GATEWAY_TOKEN=

# Optional for whatsapp-gateway: outbound send-control policy — the messenger
# analogue of EMAIL_SEND_POLICY. Like e-mail, the category is keyed by the
# SENDING identity (this gateway's own WHATSAPP_ACCOUNT number), NOT the
# recipient: what governs an autonomous send is which number it goes out as. A
# dedicated agent number can be granted "allow" while the user's own number stays
# "verify". Categories allow / trust / verify (see EMAIL_SEND_POLICY below). An
# account matching no entry and no "*" wildcard falls back to verify (fail-safe,
# same as e-mail), so an undeclared account can never post autonomously. Pending
# sends appear on /sends alongside e-mail and Signal approvals.
# WHATSAPP_SEND_POLICY=[{"number":"+15551234567","category":"verify"},{"number":"+15558888888","category":"allow"}]
#
# Optional: restrict answer-language detection for control-mode replies.
# WHATSAPP_SUPPORTED_LANGUAGES=de,en

# Outbound Telegram (scripts/telegram-push.py → telegram-gateway /send).
# The messenger sibling of the Signal/WhatsApp gateways: a dedicated service logs
# in as your OWN Telegram account (an MTProto user client via Telethon), so it
# acts as you — messages your contacts as you, reads your own DMs (real inbox
# triage), and sees your contact directory. Credentials live only in the gateway.
#   TELEGRAM_API_ID / TELEGRAM_API_HASH: your MTProto app credentials from
#                              https://my.telegram.org → API development tools.
#   TELEGRAM_PHONE:            the account's phone number (E.164), used at login.
#   TELEGRAM_ACCOUNT:          optional explicit sending identity for send-control
#                              (defaults to this account's @username / phone).
#   TELEGRAM_GATEWAY_MODE:     "inbox" (default) or "control" (see Signal above).
#   TELEGRAM_DEFAULT_RECIPIENT: chat_id/@username pushes go to when none is given.
#   TELEGRAM_GATEWAY_TOKEN:    shared secret; when set, /send requires it. Both
#                              the gateway and retinue read it, so set it once.
# Log in once (creates the session in the telegram-data volume; prompts for the
# code Telegram sends you, and your 2FA password if set):
#   docker compose run --rm -it telegram-gateway python3 /app/telegram-gateway.py login
# TELEGRAM_API_ID=
# TELEGRAM_API_HASH=
# TELEGRAM_PHONE=+15551234567
# TELEGRAM_ACCOUNT=@me
# TELEGRAM_GATEWAY_MODE=inbox
# TELEGRAM_DEFAULT_RECIPIENT=123456789
# TELEGRAM_GATEWAY_TOKEN=

# Optional for telegram-gateway: outbound send-control policy — the messenger
# analogue of EMAIL_SEND_POLICY. Like e-mail, the category is keyed by the
# SENDING identity (this account, TELEGRAM_ACCOUNT), NOT the recipient chat.
# Categories allow / trust / verify. An identity matching no entry and no "*"
# wildcard falls back to verify (fail-safe) — since this is your own account,
# that means every send needs approval unless you grant it explicitly. Pending
# sends appear on /sends alongside e-mail, Signal and WhatsApp approvals.
# TELEGRAM_SEND_POLICY=[{"number":"@me","category":"verify"},{"number":"*","category":"verify"}]
#
# Optional: restrict answer-language detection for control-mode replies.
# TELEGRAM_SUPPORTED_LANGUAGES=de,en

# Updater sidecar (docker-compose.yml `updater` service, scripts/self-update.py).
# HTTP trigger to rebuild/restart the whole stack
# (`git pull && docker compose build && docker compose up -d`) without SSHing
# into the host — reachable from the phone (via Traefik, token + basic auth;
# see docker-compose.override.example.yml) and from inside retinue.
# Unlike EMAIL_BACKEND_TOKEN/CONVERSATION_BACKEND_TOKEN, this cannot be
# auto-generated at container start: the updater and retinue are separate
# containers/services, so the same value must be set here and shared by both
# via env_file. Required — with no token the updater rejects every request.
# UPDATER_TOKEN=

# Optional for the gateway: use a single explicit allowlist file instead of the
# default union of every chamber's accepted-requesters.txt
# ACCEPTED_REQUESTERS_PATH=/workspace/chambers/<chamber>/accepted-requesters.txt

# Optional: Anthropic API key — only needed if authenticating via API key
# instead of logging in with your Claude.ai account (the default).
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: Claude permission mode for remote-control and web gateway invocations.
# See https://code.claude.com/docs/en/permission-modes for options
# Defaults to acceptEdits when not set.
# CLAUDE_PERMISSION_MODE=acceptEdits

# Optional: task scheduler (scripts/scheduler.py) tunables. Jobs are declared in
# chambers/<chamber>/.schedule.json; these only adjust the daemon itself.
# SCHEDULER_TICK_SECONDS=30
# SCHEDULER_JOB_TIMEOUT=900
# SCHEDULER_STATE_DIR=/root/.retinue/scheduler

# Remote access auth. The public `agents` router accepts EITHER a TLS client
# certificate OR basic auth (alternatives — see deploy/traefik/README.md).
#
# Basic-auth users, htpasswd-style (apr1/MD5 from `htpasswd -nb user pass`; double
# the `$` when copying into this file). This value is now ALSO read by the gateway,
# which verifies the password at /auth so a certificate can be offered instead.
# TRAEFIK_BASIC_AUTH_USERS=user:$$apr1$$...$$...
TRAEFIK_BASIC_AUTH_USERS=
#
# Optional: require the client certificate's Common Name to equal this value
# (extra restriction on top of CA verification). Empty = accept any cert signed
# by the client CA. Issue certs with scripts/gen-client-cert.sh.
# GATEWAY_CLIENT_CERT_CN=

# --- E-mail (scripts/email_client.py, IMAP+SMTP) -----------------------------
# Provider-independent e-mail access for the Secretary agent. Always use an
# *app password* (provider security settings), never the normal login password.
# The "default" account uses the unsuffixed variables; named accounts append an
# upper-cased suffix and are selected with `email_client.py --account <name>`.
#
# Default account (example: Zoho):
# EMAIL_USER=you@example.com
# EMAIL_PASS=
# IMAP_HOST=imap.zoho.eu
# IMAP_PORT=993
# SMTP_HOST=smtpout-mail.zoho.eu
# SMTP_PORT=587
# SENT_FOLDER=Sent
# DRAFTS_FOLDER=Drafts
# SMTP_SAVE_SENT=true
#
# Named account "ari" (Gmail). Gmail saves Sent itself, so SMTP_SAVE_SENT=false.
# Special-folder names are localized to the mailbox language — this account is
# German (run `email_client.py --account ari folders` to confirm yours):
# EMAIL_USER_ARI=assistant@example.com
# EMAIL_PASS_ARI=
# IMAP_HOST_ARI=imap.gmail.com
# SMTP_HOST_ARI=smtp.gmail.com
# SENT_FOLDER_ARI=[Gmail]/Gesendet
# DRAFTS_FOLDER_ARI=[Gmail]/Entwürfe
# SMTP_SAVE_SENT_ARI=false
#
# Additional accounts (e.g. persona mailboxes) are configured with the same
# variables above using an upper-cased suffix, then selected at call time via the
# --account flag:
#   email_client.py --account ari list --folder INBOX
# All credentials stay in this file and are covered by the credential isolation
# described below. Prefer this over --env-file for every new account.
#
# NOTE: --env-file / EMAIL_ENV_FILE loads a per-call dotenv file, but any file
# passed that way is readable by the agent and bypasses the credential isolation,
# so using it gives the agent direct SMTP/IMAP access and lets it circumvent the
# send-control policy. Avoid --env-file; add credentials here as a named account
# instead.

# --- E-mail send-control policy (sender-address based) ------------------------
# Every outgoing e-mail is governed by the *control category* of its sender
# address. EMAIL_SEND_POLICY is a JSON array of {address, category[, account]}.
# Categories:
#   verify — never sent directly; email_client.py saves a pending draft and
#            returns an approval_url. The user approves/denies on the web gateway
#            (GET /sends). Only then is the e-mail dispatched.
#   trust  — sent directly only when the model passes `send --user-approved`;
#            without that flag it falls back to the verify flow.
#   allow  — sent directly, no confirmation (use for an autonomous mailbox like
#            Ari's own address).
# "account" (optional) is the email_client --account suffix that owns the address
# (omit/null for the default account). Addresses not listed fall back to a "*"
# wildcard entry, or — absent that — to "verify" (the fail-safe default).
# EMAIL_SEND_POLICY=[{"address":"you@example.com","category":"verify"},{"address":"assistant@example.com","category":"allow","account":"ari"}]
#
# --- E-mail credential isolation (web-gateway backend) ------------------------
# SMTP/IMAP credentials are kept out of the agent's environment entirely. In
# remote-control mode the entrypoint and the scheduler strip EMAIL_PASS* from
# the agent's env and point email_client.py at the web gateway's internal
# endpoint; the gateway — the only process that keeps the credentials — runs the
# real IMAP/SMTP commands. The agent then cannot read the passwords nor bypass
# the send-control policy (e.g. it has no `approve` command; approvals happen
# only on the web gateway). This is gated by a shared EMAIL_BACKEND_TOKEN; if you
# do not set one, the entrypoint auto-generates a random token at start-up, since
# there is no legitimate reason for an agent to bypass the policy. Set it
# explicitly only if another process needs to reach the internal endpoint.
# Note: persona secret files loaded via `--env-file` still sit on a disk the
# agent can read (see the --env-file warning above).
# EMAIL_BACKEND_TOKEN=
#
# --- Conversation tabs (dashboard chat backend) ------------------------------
# The dashboard's conversation-tabs card backs onto the gateway's /conversations
# API. Agents can also *open* a thread that needs the user's decision via the
# token-gated /internal/conversations endpoint (scripts/conversation-push.py).
# Like EMAIL_BACKEND_TOKEN, the entrypoint auto-generates a random token at
# start-up when none is supplied; set it explicitly only if another process
# needs to reach the internal endpoint.
# CONVERSATION_BACKEND_TOKEN=
#
# Public base URL used to build approval links (falls back to CONVERSATION_BASE_URL):
# SEND_APPROVAL_BASE_URL=https://retinue.example.com
